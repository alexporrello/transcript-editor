{
    "singleQuote": true,
    "trailingComma": "none",
    "singleAttributePerLine": true,
    "tabWidth": 4,
    "jsxSingleQuote": true,
    "bracketSameLine": true,
    "printWidth": 80,
    "htmlWhitespaceSensitivity": "strict",
    "embeddedLanguageFormatting": "off",
    "overrides": [
        {
            "files": "*.html",
            "options": {
                "parser": "angular"
            }
        }
    ]
}